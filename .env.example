# PostgreSQL
POSTGRES_USER=wallet
POSTGRES_PASSWORD=wallet_secret
POSTGRES_DB=wallet_db
DATABASE_URL=postgresql://wallet:wallet_secret@localhost:5433/wallet_db?schema=public

# API
API_PORT=3001
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3000

# Web (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:3001
API_URL=http://localhost:3001
